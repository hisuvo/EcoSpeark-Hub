model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  ideas       Idea[]

  @@index([name], name: "category_name_idx")
  @@index([description], name: "category_description_idx")
  @@map("categories")
} 